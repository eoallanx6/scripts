local function New(class, properties, parent)
    local object = Instance.new(class)
    for key, value in pairs(properties or {}) do object[key] = value end
    object.Parent = parent
    return object
end
local function Tween(object, duration, values)
    local tween=TweenService:Create(object,TweenInfo.new(duration,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),values)
    tween:Play()
    return tween
end
local function TweenWithInfo(object, tweenInfo, values)
    local tween=TweenService:Create(object,tweenInfo,values)
    tween:Play()
    return tween
end
local function Round(object, radius) New("UICorner", {CornerRadius=UDim.new(0,radius)}, object) end
local function Stroke(object, transparency) New("UIStroke", {Color=Theme.Stroke,Transparency=transparency or .5}, object) end
local function Text(parent, value, size, color, bold)
    return New("TextLabel", {BackgroundTransparency=1,Text=value,TextColor3=color or Theme.Text,Font=bold and Enum.Font.GothamBold or Enum.Font.GothamMedium,TextSize=size or 12,TextXAlignment=Enum.TextXAlignment.Left,Size=UDim2.fromScale(1,1)}, parent)
end
local function GuiParent()
    local ok, holder = pcall(function() return gethui and gethui() end)
