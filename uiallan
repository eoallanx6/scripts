                if not serverStats then return nil end
                return serverStats:FindFirstChild("Data Ping") or serverStats:FindFirstChild("Ping")
                    or (function()
                        for _,item in ipairs(serverStats:GetChildren()) do
                            if string.find(string.lower(item.Name),"ping",1,true) then return item end
                        end
                    end)()
            end)
            if ok then pingStat=found end
        end
        if not pingStat then return "-- ms" end
        local okNumber,number=pcall(function() return pingStat:GetValue() end)
        if okNumber and type(number)=="number" then return tostring(math.floor(number+0.5)).." ms" end
