        function manager:Save(force) if not self.Dirty and not force then return true end; if type(writefile)~="function" then return false end; for id,c in pairs(self.Controls) do self.Data[id]=c:Get() end; local ok=pcall(function() if type(makefolder)=="function" and (type(isfolder)~="function" or not isfolder(self.Folder)) then makefolder(self.Folder) end; writefile(self.FileName,HttpService:JSONEncode(self.Data)); self.Dirty=false end); return ok end
