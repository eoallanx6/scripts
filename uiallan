do
    local NativeCreateWindow = AllanUI.CreateWindow
    function AllanUI:CreateWindow(options)
        local window = NativeCreateWindow(self, options)
        function window:AddTab(info)
            info = info or {}
            return self:AddPage(info.Title or "Tab", {
                Icon = info.Icon,
                IconName = info.IconName or info.Icon,
                CardTitle = info.Title or "Tab",
            })
        end
        function window:SelectTab(target)
            if type(target) == "number" then
                target = self.Pages[target]
            end
            if target and target.Select then
                target:Select()
            end
        end
        function window:CreateSaveManager(folder)
            return AllanUI:CreateSaveManager(folder)
        end
        return window
    end
end

function AllanUI:CreateSaveManager(folder)
    local HttpService = game:GetService("HttpService")
    local manager = {Controls = {}, Data = {}, Dirty = false, Folder = folder or "AllanHub/Configs"}
    manager.FileName = manager.Folder .. "/" .. Player.UserId .. "_" .. game.PlaceId .. ".json"
    function manager:Load()
        if type(isfile) ~= "function" or not isfile(self.FileName) then return end
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(self.FileName)) end)
        if ok and type(data) == "table" then self.Data = data end
    end
    function manager:Register(id, control)
        self.Controls[id] = control
        if self.Data[id] ~= nil and control.Set then control:Set(self.Data[id]) end
        if control.OnChanged then
            control:OnChanged(function(value)
                self.Data[id] = value
                self.Dirty = true
            end)
        end
        return control
    end
    function manager:Save(force)
        if not self.Dirty and not force then return true end
        if type(writefile) ~= "function" then return false end
        for id, control in pairs(self.Controls) do
            if control.Get then self.Data[id] = control:Get() end
        end
        local ok = pcall(function()
            if type(makefolder) == "function" and (type(isfolder) ~= "function" or not isfolder(self.Folder)) then makefolder(self.Folder) end
            writefile(self.FileName, HttpService:JSONEncode(self.Data))
            self.Dirty = false
        end)
        return ok
    end
    function manager:Reset()
        self.Data = {}
        self.Dirty = false
        if type(delfile) == "function" and type(isfile) == "function" and isfile(self.FileName) then delfile(self.FileName) end
    end
    manager:Load()
    return manager
end

return AllanUI
